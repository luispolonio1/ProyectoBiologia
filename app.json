{
  "expo": {
    "name": "AquaNodes",
    "slug": "ProyectoBiologia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/iconApp.png",
    "scheme": "proyectobiologia",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/iconApp.png",
        "backgroundImage": "./assets/images/iconApp.png",
        "monochromeImage": "./assets/images/iconApp.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.luis2002p.ProyectoBiologia"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/iconApp.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/iconApp.png",
          "imageWidth": 150,
          "resizeMode": "contain",
          "backgroundColor": "#3179ad",
          "dark": {
            "backgroundColor": "#3179ad"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "21750047-06a2-44fa-b1ed-52f5577b6e81"
      }
    }
  }
}
